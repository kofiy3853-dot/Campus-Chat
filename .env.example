# Backend Environment Variables (.env in /backend)
PORT=5000
MONGODB_URI=your_mongodb_uri
JWT_SECRET=your_jwt_secret
REDIS_URL=your_redis_url
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_name
FIREBASE_SERVICE_ACCOUNT_KEY=your_firebase_service_account_json
NODE_ENV=production

# Frontend Environment Variables (.env.production in /frontend)
VITE_API_URL=https://campus-chat-ira2.onrender.com
